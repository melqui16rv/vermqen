{% extends "layouts/base.twig" %}

{% block content %}
  <section class="hero-card p-4 p-lg-5 text-center">
    <p class="hero-eyebrow mb-2">404</p>
    <h1 class="display-6 fw-bold mb-3">La ruta solicitada no existe</h1>
    <p class="text-secondary mb-4">
      No encontramos el módulo <code>{{ requestedSlug }}</code>. Verifica el slug o crea esa ventana en el registro de contenido.
    </p>
    <a href="{{ homePath }}" class="btn btn-primary rounded-pill px-4">
      Volver al inicio
    </a>
  </section>
{% endblock %}
