{% extends "layouts/base.twig" %}

{% block content %}
  <div class="modules-layout">
    {% include 'partials/sidebar.twig' %}

    {# ── CONTENIDO PRINCIPAL ──────────────────────────────────────────── #}
    <main class="modules-main">
      <section class="hero-card p-3 p-lg-4 mb-3" data-aos="fade-up" data-aos-duration="800">
        <div class="row g-4 align-items-center">
          <div class="col-lg-8">
            <p class="hero-eyebrow mb-2">Documentación técnica centralizada</p>
            <h1 class="display-6 fw-bold mb-3">Wiki <span class="text">App CIDE</span></h1>
            <p class="lead text-secondary mb-4">
              Base de documentación del proyecto, organizada por categorías y módulos.
            </p>
            <div class="d-flex flex-wrap gap-2">
              <a class="btn btn-primary btn-lg rounded-pill px-4" href="{{ categories[0].path }}">Explorar DevOps</a>
            </div>
            <div class="hero-metrics mt-4">
              <span><strong>{{ modules|length }}</strong> módulos documentados</span>
              <span><strong>{{ categories|length }}</strong> categorías</span>
            </div>
          </div>
          <div class="col-lg-4">
            <div class="glass-panel p-3 p-lg-4">
              <p class="text-uppercase small text-secondary mb-2">Modo hosting compartido</p>
              <p class="mb-2">Rutas limpias con rewrite, fallback sin rewrite:</p>
              <code class="code-chip">{{ queryRouteExample }}</code>
            </div>
          </div>
        </div>

          <!-- Compact strip shown while searching to save vertical space -->
          <div x-show="compactMode && !open" class="compact-search-strip d-flex gap-2 align-items-center mt-2" style="overflow:hidden">
            <template x-for="m in compactItems()" :key="m._id">
              <button type="button" @click="irAModulo(m)" class="btn btn-sm btn-light text-truncate" style="max-width:160px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                <span x-text="m.titulo"></span>
              </button>
            </template>
            <div class="ms-auto d-flex gap-2">
              <button type="button" @click="open = true" class="btn btn-sm btn-outline-primary">Mostrar</button>
              <button type="button" @click="handleExternalSearch('')" class="btn btn-sm btn-outline-secondary">Limpiar</button>
            </div>
          </div>
      </section>

      <section x-data="moduloApp({ apiBase: '{{ assetBase }}/api', glossaryPath: '{{ glossaryPath }}' })" x-init="init()" class="module-suggestions-section mb-3" data-aos="fade-up" data-aos-delay="100">
        <div class="glass-panel p-2 p-md-4">
          <div class="d-flex align-items-center justify-content-between gap-3 mb-2">
            <div class="d-flex align-items-center gap-3">
              <button type="button" @click="toggleOpen()" class="btn btn-sm btn-outline-secondary" aria-expanded="false" x-bind:aria-expanded="open">
                <i class="bi" x-bind:class="open ? 'bi-chevron-up' : 'bi-chevron-down'"></i>
                <span class="ms-2 d-none d-md-inline">Recomendaciones</span>
              </button>
              <div class="d-none d-md-flex align-items-center gap-2 small text-secondary">
                <template x-for="m in masVistos.slice(0,2)" :key="m._id">
                  <span x-text="m.titulo" class="badge bg-secondary bg-opacity-10 text-secondary"></span>
                </template>
              </div>
            </div>
            <div class="text-end">
              <small class="text-secondary">Mostrar módulos más vistos y sugeridos</small>
            </div>
          </div>

          <div x-show="open" x-transition class="mt-3">
            <div class="row g-4">
              <template x-for="modulo in masVistos" :key="modulo._id">
                <div class="col-md-6 col-lg-4">
                  <button type="button" @click="irAModulo(modulo)" class="module-card popular-card p-3 h-100 d-flex flex-column text-start" aria-label="Abrir módulo más visto">
                    <div class="d-flex align-items-start justify-content-between mb-2 gap-2">
                      <h3 class="module-card-title mb-0" x-text="modulo.titulo"></h3>
                      <span class="badge bg-secondary bg-opacity-15 text-secondary" x-text="modulo.vistas + ' vistas'"></span>
                    </div>
                    <p class="text-secondary small mb-3" x-html="procesarTextoGlosario(modulo.descripcion)"></p>
                    <span class="badge bg-primary bg-opacity-10 text-primary mt-auto align-self-start">Top 3</span>
                  </button>
                </div>
              </template>

              <template x-if="masVistos.length === 0">
                <div class="col-12 text-center text-secondary">
                  <p>Cargando módulos más vistos...</p>
                </div>
              </template>
            </div>

            <div class="row g-4 mt-3">
              <div class="col-12">
                <div class="d-flex align-items-center justify-content-between gap-3 mb-2">
                  <div>
                    <h2 class="h6 mb-1">Módulos que te pueden interesar</h2>
                    <p class="text-secondary mb-0 small">Últimos módulos añadidos, excluyendo los más vistos.</p>
                  </div>
                  <span class="badge bg-success bg-opacity-10 text-success border border-success-subtle">Novedades</span>
                </div>
              </div>

              <template x-for="modulo in tePuedenInteresar" :key="modulo._id">
                <div class="col-md-6 col-lg-4">
                  <button type="button" @click="irAModulo(modulo)" class="module-card suggestion-card p-3 h-100 d-flex flex-column text-start" aria-label="Abrir módulo sugerido">
                    <div class="d-flex align-items-start justify-content-between mb-2 gap-2">
                      <h3 class="module-card-title mb-0" x-text="modulo.titulo"></h3>
                      <span class="badge bg-success bg-opacity-15 text-success" x-text="new Date(modulo.fechaCreacion).toLocaleDateString('es-ES')"></span>
                    </div>
                    <p class="text-secondary small mb-3" x-html="procesarTextoGlosario(modulo.descripcion)"></p>
                    <span class="badge bg-info bg-opacity-10 text-info mt-auto align-self-start">Reciente</span>
                  </button>
                </div>
              </template>

              <template x-if="tePuedenInteresar.length === 0">
                <div class="col-12 text-center text-secondary">
                  <p>Cargando sugerencias recientes...</p>
                </div>
              </template>
            </div>
          </div>
        </div>
      </section>

      <section class="categories-showcase mb-3" data-aos="fade-up" data-aos-delay="150">
        <div class="categories-header">
          <h2 class="categories-title">Explora por Categoría</h2>
          <p class="categories-subtitle">Selecciona una categoría para ver todos los módulos disponibles</p>
        </div>
        
        <div class="categories-grid">
          {% for category in categories %}
            <a href="{{ category.path }}" class="category-card" data-aos="zoom-in" data-aos-delay="{{ loop.index * 100 }}">
              <div class="category-card-inner">
                <div class="category-icon">
                  {% if loop.index == 1 %}<i class="bi bi-gear"></i>
                  {% elseif loop.index == 2 %}<i class="bi bi-box-seam"></i>
                  {% else %}<i class="bi bi-diagram-3"></i>{% endif %}
                </div>
                <h3 class="category-name">{{ category.label }}</h3>
                <p class="category-count">{{ category.modules|length }} módulos</p>
                <div class="category-footer">
                  <span class="explore-text">Explorar</span>
                  <i class="bi bi-arrow-right"></i>
                </div>
              </div>
            </a>
          {% endfor %}
        </div>
      </section>
    </main>
  </div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const categoryToggles = document.querySelectorAll('.sidebar-category-toggle');
  categoryToggles.forEach(toggle => {
    const categoryKey = toggle.dataset.category;
    const modulesList = document.querySelector(`.sidebar-modules[data-category="${categoryKey}"]`);
    if (toggle === categoryToggles[0]) {
      modulesList.classList.add('open');
      toggle.setAttribute('aria-expanded', 'true');
    }
    toggle.addEventListener('click', function(e) {
      e.preventDefault();
      const isOpen = modulesList.classList.contains('open');
      categoryToggles.forEach(t => {
        if (t !== toggle) {
          const key = t.dataset.category;
          const list = document.querySelector(`.sidebar-modules[data-category="${key}"]`);
          list.classList.remove('open');
          t.setAttribute('aria-expanded', 'false');
        }
      });
      modulesList.classList.toggle('open');
      toggle.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
    });
  });

  const searchInput = document.getElementById('moduleSearch');
  const categoryFilter = document.getElementById('categoryFilter');
  function filterModules() {
    const searchTerm = searchInput.value.toLowerCase();
    const selectedCategory = categoryFilter.value;
    const moduleLinks = document.querySelectorAll('.sidebar-module-link');
    moduleLinks.forEach(link => {
      const title = link.textContent.toLowerCase();
      const category = link.dataset.category;
      const matchesSearch = searchTerm === '' || title.includes(searchTerm);
      const matchesCategory = selectedCategory === '' || category === selectedCategory;
      link.parentElement.style.display = (matchesSearch && matchesCategory) ? 'block' : 'none';
    });
  }
  searchInput.addEventListener('input', filterModules);
  categoryFilter.addEventListener('change', filterModules);
});
</script>

<style>
.filter-select {
  -webkit-appearance: none;
  -moz-appearance: none;
  appearance: none;
  background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='rgba(139, 92, 246, 0.5)' stroke-width='2'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");
  background-repeat: no-repeat;
  background-position: right 0.6rem center;
  background-size: 1.2em 1.2em;
  padding-right: 2.5rem;
}
.filter-select option { background: #0a0e27; color: #f3f4f6; }
body.light-mode .filter-select option { background: #ffffff; color: #1f2937; }
</style>
{% endblock %}