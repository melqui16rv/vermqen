{% extends "layouts/base.twig" %}

{% block content %}
  {# ── Hero ────────────────────────────────────────────────────────── #}
  <section class="hero-card p-4 p-lg-5 mb-4 mb-lg-5" data-aos="fade-up" data-aos-duration="800">
    <div class="row g-4 align-items-center">
      <div class="col-lg-8">
        <p class="hero-eyebrow mb-2">Documentación técnica centralizada</p>
        <h1 class="display-6 fw-bold mb-3">Wiki <span class="text-gradient">VERMQEN</span></h1>
        <p class="lead text-secondary mb-4">
          Base de documentación del proyecto, organizada por categorías y módulos.
        </p>
        {% if modules|length > 0 %}
          <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-primary btn-lg rounded-pill px-4" href="{{ modules[0].path }}">Explorar primer módulo</a>
          </div>
        {% endif %}
        <div class="hero-metrics mt-4">
          <span><strong>{{ modules|length }}</strong> módulos documentados</span>
          <span><strong>{{ categories|length }}</strong> categorías</span>
        </div>
      </div>
      <div class="col-lg-4">
        <div class="glass-panel p-3 p-lg-4">
          <p class="text-uppercase small text-secondary mb-2">Modo hosting compartido</p>
          <p class="mb-2">Rutas limpias con rewrite, fallback sin rewrite:</p>
          <code class="code-chip">{{ queryRouteExample }}</code>
        </div>
      </div>
    </div>
  </section>

  {# ── Buscador ─────────────────────────────────────────────────────── #}
  <section class="mb-4" data-aos="fade-up" data-aos-delay="80">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-1">
      <div>
        <h2 class="h4 mb-1">Módulos disponibles</h2>
        <p class="text-secondary mb-0">Cada tarjeta representa una sección de documentación del sistema.</p>
      </div>
      <div class="col-md-4 col-lg-3 p-0">
        <input
          type="search"
          id="module-search"
          class="form-control bg-dark-subtle border-secondary-subtle text-light"
          placeholder="Filtrar módulo..."
          data-module-search
          autocomplete="off"
        >
      </div>
    </div>
  </section>

  {# ── Tarjetas agrupadas por categoría ─────────────────────────────── #}
  {% for category in categories %}
    <section class="mb-5" data-category-section data-category-key="{{ category.key }}" data-aos="fade-up" data-aos-delay="{{ loop.index * 60 }}">
      <div class="d-flex align-items-center gap-3 mb-3">
        <h3 class="h5 mb-0 text-secondary text-uppercase fw-semibold" style="letter-spacing:.06em">{{ category.label }}</h3>
        <span class="badge rounded-pill text-bg-secondary">{{ category.modules|length }}</span>
        <hr class="flex-grow-1 border-secondary-subtle my-0">
      </div>
      <div class="row g-3 g-lg-4" data-module-list>
        {% for module in category.modules %}
          <div class="col-md-6 col-xl-4"
               data-module-card
               data-filter-text="{{ (module.title ~ ' ' ~ module.summary ~ ' ' ~ category.label)|lower }}">
            <article class="module-card h-100 p-4">
              <span class="badge rounded-pill text-bg-dark border border-secondary-subtle mb-3">{{ module.tag }}</span>
              <h4 class="h5 mb-2">{{ module.title }}</h4>
              <p class="text-secondary">{{ module.summary }}</p>
              <a href="{{ module.path }}" class="stretched-link text-decoration-none fw-semibold">
                Ver manual <i class="bi bi-arrow-right-short"></i>
              </a>
            </article>
          </div>
        {% endfor %}
      </div>
    </section>
  {% endfor %}

  <p class="text-secondary small mt-2 mb-0" data-no-results hidden>
    No hay módulos que coincidan con la búsqueda.
  </p>
{% endblock %}
