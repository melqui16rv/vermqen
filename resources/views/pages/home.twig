{% extends "layouts/base.twig" %}

{% block content %}
  <div class="modules-layout">
    
    {# ── SIDEBAR COMPACTA ─────────────────────────────────────────────── #}
    <aside class="modules-sidebar compact" data-aos="fade-right" data-aos-duration="700">
      <div class="sidebar-header">
        <a href="/" class="sidebar-logo">
          <span class="brand-dot-small"></span>
          <span class="sidebar-brand">VERMQEN</span>
        </a>
      </div>
      <div class="sidebar-content">
        {% for category in categories %}
          <div class="sidebar-section">
            <h4 class="sidebar-category-title">{{ category.label }}</h4>
            <ul class="sidebar-modules">
              {% for module in category.modules %}
                <li class="sidebar-module-item">
                  <a href="{{ module.path }}" class="sidebar-module-link" title="{{ module.title }}">
                    {{ module.title }}
                  </a>
                </li>
              {% endfor %}
            </ul>
          </div>
        {% endfor %}
      </div>
    </aside>

    {# ── CONTENIDO PRINCIPAL ──────────────────────────────────────────── #}
    <main class="modules-main">
      {# Hero #}
      <section class="hero-card p-4 p-lg-5 mb-5" data-aos="fade-up" data-aos-duration="800">
        <div class="row g-4 align-items-center">
          <div class="col-lg-8">
            <p class="hero-eyebrow mb-2">Documentación técnica centralizada</p>
