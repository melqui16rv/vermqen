{% extends "layouts/base.twig" %}

{% block content %}
<div class="modules-layout">
    <aside class="modules-sidebar compact">
        <div class="sidebar-header">
            <a href="/" class="sidebar-logo">
                <div class="logo-icon">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <circle cx="12" cy="12" r="10" fill="url(#gradient-logo)"/>
                        <circle cx="12" cy="12" r="6" fill="#0a0e27" opacity="0.8"/>
                        <text x="12" y="15" font-size="10" font-weight="700" text-anchor="middle" fill="#8b5cf6" font-family="Inter">V</text>
                        <defs>
                            <linearGradient id="gradient-logo" x1="0%" y1="0%" x2="100%" y2="100%">
                                <stop offset="0%" stop-color="#8b5cf6"/>
                                <stop offset="100%" stop-color="#ec4899"/>
                            </linearGradient>
                        </defs>
                    </svg>
                </div>
                <span class="sidebar-brand">VERMQEN</span>
            </a>
        </div>

        {# Buscador #}
        <div class="sidebar-search">
            <input type="text" id="moduleSearch" class="search-input" placeholder="Buscar módulo..." />
            <i class="bi bi-search search-icon"></i>
        </div>

        {# Filtrador #}
        <div class="sidebar-filter">
            <select id="categoryFilter" class="filter-select">
                <option value="">Todas las categorías</option>
                {% for category in categories %}
                    <option value="{{ category.key }}">{{ category.label }}</option>
                {% endfor %}
            </select>
            <i class="bi bi-funnel filter-icon"></i>
        </div>

        <div class="sidebar-content">
            {% for category in categories %}
                <div class="sidebar-section">
                    <button class="sidebar-category-toggle" data-category="{{ category.key }}">
                        <span class="category-title">{{ category.label }}</span>
                        <i class="bi bi-chevron-down toggle-icon"></i>
                    </button>
                    <ul class="sidebar-modules" data-category="{{ category.key }}" style="max-height: 0;">
                        {% for module in category.modules %}
                            <li class="sidebar-module-item">
                                <a href="{{ module.path }}" class="sidebar-module-link" data-category="{{ category.key }}" title="{{ module.title }}">
                                    <span class="module-dot"></span>
                                    {{ module.title }}
                                </a>
                            </li>
                        {% endfor %}
                    </ul>
                </div>
            {% endfor %}
        </div>
    </aside>

    <main class="modules-main">
        <!-- Hero Section -->
        <section class="category-hero">
            <div class="hero-content">
                <h1 class="hero-title">{{ categoryLabel }}</h1>
                <p class="hero-subtitle">Explora todos los módulos disponibles en esta categoría</p>
            </div>
        </section>

        <!-- Category Modules Grid -->
        <section class="category-modules-section">
            <div class="modules-grid">
                {% for module in modules %}
                    <a href="{{ module.path }}" class="module-card" data-aos="fade-up" data-aos-delay="{{ loop.index * 100 }}">
                        <div class="module-card-inner">
                            <div class="module-card-header">
                                <div class="module-card-color" style="background-color: var(--accent-{{ (loop.index0 % 8) + 1 }})"></div>
                                <span class="module-card-tag">{{ module.tag }}</span>
                            </div>
                            <div class="module-card-body">
                                <h3 class="module-card-title">{{ module.title }}</h3>
                                {% if module.summary %}
                                    <p class="module-card-summary">{{ module.summary }}</p>
                                {% endif %}
                            </div>
                            <div class="module-card-footer">
                                <span class="module-card-link">Leer más →</span>
                            </div>
                        </div>
                    </a>
                {% endfor %}
            </div>
        </section>
    </main>
</div>

<style>
.category-hero {
    background: linear-gradient(135deg, rgba(139, 92, 246, 0.1), rgba(236, 72, 153, 0.1));
    padding: 3rem 2rem;
    border-radius: 1rem;
    margin-bottom: 3rem;
    backdrop-filter: blur(10px);
    border: 1px solid rgba(139, 92, 246, 0.2);
}

.hero-content {
    max-width: 800px;
}

.hero-title {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    background: linear-gradient(135deg, #8b5cf6, #ec4899);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.hero-subtitle {
    font-size: 1.1rem;
    color: rgba(243, 244, 246, 0.7);
}

.category-modules-section {
    margin-top: 2rem;
}

.modules-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 2rem;
}

.module-card {
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.23, 1, 0.320, 1);
}

.module-card:hover .module-card-inner {
    transform: translateY(-8px);
    border-color: rgba(139, 92, 246, 0.6);
    box-shadow: 0 16px 40px rgba(139, 92, 246, 0.2);
}

.module-card:hover .module-card-link {
    transform: translateX(4px);
}

.module-card-inner {
    background: linear-gradient(135deg, rgba(17, 24, 39, 0.6), rgba(17, 24, 39, 0.4));
    border: 1px solid rgba(139, 92, 246, 0.2);
    border-radius: 0.75rem;
    padding: 1.5rem;
    transition: all 0.3s cubic-bezier(0.23, 1, 0.320, 1);
    display: flex;
    flex-direction: column;
    height: 100%;
}

.module-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
}

.module-card-color {
    width: 24px;
    height: 24px;
    border-radius: 0.5rem;
    opacity: 0.8;
}

.module-card-tag {
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.25rem 0.75rem;
    background: rgba(139, 92, 246, 0.2);
    border-radius: 999px;
    color: #a78bfa;
    text-transform: uppercase;
    letter-spacing: 0.05em;
}

.module-card-body {
    flex: 1;
    margin-bottom: 1rem;
}

.module-card-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: #f3f4f6;
    margin-bottom: 0.5rem;
}

.module-card-summary {
    font-size: 0.9rem;
    color: rgba(243, 244, 246, 0.6);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
}

.module-card-footer {
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.module-card-link {
    font-size: 0.9rem;
    color: #8b5cf6;
    font-weight: 500;
    transition: all 0.3s ease;
}

/* Light mode */
body.light-mode .category-hero {
    background: linear-gradient(135deg, rgba(139, 92, 246, 0.08), rgba(236, 72, 153, 0.04));
    border-color: rgba(139, 92, 246, 0.1);
}

body.light-mode .hero-subtitle {
    color: rgba(55, 65, 81, 0.7);
}

body.light-mode .module-card-inner {
    background: linear-gradient(135deg, rgba(249, 250, 251, 0.9), rgba(243, 244, 246, 0.8));
    border-color: rgba(139, 92, 246, 0.15);
}

body.light-mode .module-card-title {
    color: #1f2937;
}

body.light-mode .module-card-summary {
    color: rgba(55, 65, 81, 0.7);
}

/* Responsive */
@media (max-width: 1024px) {
    .modules-layout {
        grid-template-columns: 160px 1fr;
        gap: 1.5rem;
    }

    .hero-title {
        font-size: 2rem;
    }

    .modules-grid {
        grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
        gap: 1.5rem;
    }
}

@media (max-width: 768px) {
    .modules-layout {
        display: flex;
        flex-direction: column;
    }

    .modules-sidebar {
        position: static;
        max-height: none;
        margin-bottom: 2rem;
    }

    .hero-title {
        font-size: 1.5rem;
    }

    .modules-grid {
        grid-template-columns: 1fr;
    }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // ────── TOGGLE DE CATEGORÍAS ──────
  const categoryToggles = document.querySelectorAll('.sidebar-category-toggle');
  
  categoryToggles.forEach(toggle => {
    const categoryKey = toggle.dataset.category;
    const modulesList = document.querySelector(`.sidebar-modules[data-category="${categoryKey}"]`);
    
    // Expandir la primera categoría por defecto
    if (toggle === categoryToggles[0]) {
      modulesList.classList.add('open');
      toggle.setAttribute('aria-expanded', 'true');
    }
    
    toggle.addEventListener('click', function(e) {
      e.preventDefault();
      const isOpen = modulesList.classList.contains('open');
      
      // Cerrar otras categorías
      categoryToggles.forEach(t => {
        if (t !== toggle) {
          const key = t.dataset.category;
          const list = document.querySelector(`.sidebar-modules[data-category="${key}"]`);
          list.classList.remove('open');
          t.setAttribute('aria-expanded', 'false');
        }
      });
      
      // Toggle la actual
      modulesList.classList.toggle('open');
      toggle.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
    });
  });

  // ────── BUSCADOR DE MÓDULOS ──────
  const searchInput = document.getElementById('moduleSearch');
  const categoryFilter = document.getElementById('categoryFilter');
  
  function filterModules() {
    const searchTerm = searchInput.value.toLowerCase();
    const selectedCategory = categoryFilter.value;
    const moduleLinks = document.querySelectorAll('.sidebar-module-link');
    
    moduleLinks.forEach(link => {
      const title = link.textContent.toLowerCase();
      const category = link.dataset.category;
      
      const matchesSearch = searchTerm === '' || title.includes(searchTerm);
      const matchesCategory = selectedCategory === '' || category === selectedCategory;
      
      if (matchesSearch && matchesCategory) {
        link.parentElement.style.display = 'block';
      } else {
        link.parentElement.style.display = 'none';
      }
    });
  }
  
  searchInput.addEventListener('input', filterModules);
  categoryFilter.addEventListener('change', filterModules);
});
</script>

<style>
/* Mejorar la apariencia del select en diferentes navegadores */
.filter-select {
  -webkit-appearance: none;
  -moz-appearance: none;
  appearance: none;
  background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='rgba(139, 92, 246, 0.5)' stroke-width='2'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");
  background-repeat: no-repeat;
  background-position: right 0.6rem center;
  background-size: 1.2em 1.2em;
  padding-right: 2.5rem;
}

.filter-select option {
  background: #0a0e27;
  color: #f3f4f6;
}

body.light-mode .filter-select option {
  background: #ffffff;
  color: #1f2937;
}
</style>
{% endblock %}
