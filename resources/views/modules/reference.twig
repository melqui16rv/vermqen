{% extends "layouts/base.twig" %}

{% block content %}
  <div class="modules-layout">
    {% include 'partials/sidebar.twig' %}
    <main class="modules-main">
      {# ── Back ────────────────────────────────────────────────────────── #}
      <a href="#" onclick="history.back(); return false;" class="btn btn-link text-secondary">
        Volver a la página anterior
      </a>

      <section class="hero-card p-4 p-lg-5 mb-4" data-aos="fade-up" data-aos-duration="800">
        <div class="d-flex flex-wrap gap-2 mb-3">
          <span class="badge rounded-pill text-bg-dark border border-secondary-subtle">{{ module.tag }}</span>
          <span class="badge rounded-pill text-bg-success-subtle text-success-emphasis border border-success-subtle">Referencia</span>
        </div>
        <h1 class="display-6 fw-bold mb-3">{{ module.title }}</h1>
        <p class="lead text-secondary mb-0">{{ module.intro }}</p>
      </section>

      <link rel="stylesheet" href="/assets/css/modules/reference.css">

  {# ── Capacidades / Features ───────────────────────────────────────── #}
  {% if module.features %}
    <section class="row g-3 g-lg-4 mb-4">
      {% set colors = ['primary', 'success', 'warning', 'info', 'danger'] %}
      {% for feature in module.features %}
        {% set color = cycle(colors, loop.index0) %}
        <div class="col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="{{ loop.index * 70 }}">
          <article class="module-card feature-card h-100 p-4 border-start border-4 border-{{ color }}" tabindex="0">
            <div class="icon-pill feature-icon-wrapper mb-3 text-{{ color }} bg-{{ color }} bg-opacity-10 border border-{{ color }}-subtle">
              <i class="bi {{ feature.icon }}"></i>
            </div>
            <h2 class="h6 fw-bold text-light mb-0">{{ feature.title }}</h2>
            <div class="feature-text-wrapper">
              <div class="feature-text">
                <p class="text-secondary mt-2 mb-0 small">{{ feature.text }}</p>
              </div>
            </div>
          </article>
        </div>
      {% endfor %}
    </section>
  {% endif %}

  {# ── Arquitectura y Desarrollo ──────────────────────────────────────── #}
  {% if module.architecture_docs %}
    <section class="mb-5" data-aos="fade-up" data-aos-delay="100">
      <article class="glass-panel p-4 p-lg-5">
        <h2 class="h4 mb-4 fw-bold">
          <i class="bi bi-braces me-2 text-info"></i>Arquitectura y Desarrollo
        </h2>
        <div class="d-flex flex-column gap-4">
          {% for doc in module.architecture_docs %}
            <div class="architecture-block">
              <h3 class="h6 fw-bold mb-2 text-primary">{{ doc.title }}</h3>
              <p class="text-secondary mb-3">{{ doc.description }}</p>
              {% if doc.code %}
                <pre class="mb-0 p-3 rounded-3 border border-secondary-subtle small"
                     style="background:rgba(0,0,0,.35);color:#e2e8f0;overflow-x:auto;white-space:pre;line-height:1.5;"><code>{{ doc.code }}</code></pre>
              {% endif %}
            </div>
            {% if not loop.last %}<hr class="border-secondary opacity-25">{% endif %}
          {% endfor %}
        </div>
      </article>
    </section>
  {% endif %}

  {# ── Especificaciones Técnicas para Desarrolladores ──────────────── #}
  {% if module.developer_docs %}
    <section class="mb-5" data-aos="fade-up" data-aos-delay="100">
      <h2 class="h4 mb-4 fw-bold">
        <i class="bi bi-code-slash me-2 text-info"></i>Especificaciones Técnicas
      </h2>
      <div class="row g-4">
      
        {# UI Components #}
        {% if module.developer_docs.ui_components %}
        <div class="col-lg-6">
          <article class="glass-panel p-4 h-100">
            <h3 class="h5 mb-3"><i class="bi bi-window-sidebar me-2 text-primary"></i>Componentes de UI</h3>
            <p class="text-secondary small mb-3">{{ module.developer_docs.ui_components.navbar_context }}</p>
            {% if module.developer_docs.ui_components.sub_nav_tabs %}
              <div class="d-flex flex-wrap gap-2">
                {% for tab in module.developer_docs.ui_components.sub_nav_tabs %}
                  <span class="badge bg-primary bg-opacity-10 text-primary border border-primary-subtle">{{ tab }}</span>
                {% endfor %}
              </div>
            {% endif %}
          </article>
        </div>
        {% endif %}

        {# Search Filters #}
        {% if module.developer_docs.search_filters %}
        <div class="col-lg-6">
          <article class="glass-panel p-4 h-100">
            <h3 class="h5 mb-3"><i class="bi bi-funnel me-2 text-warning"></i>Filtros de Búsqueda</h3>
            <div class="d-flex flex-column gap-3">
              {% for key, filters in module.developer_docs.search_filters %}
                <div class="workflow-step p-3">
                  <p class="fw-semibold text-capitalize mb-2">{{ key|replace({'_': ' '}) }}</p>
                  <ul class="list-unstyled mb-0 small text-secondary">
                    {% if filters.input_principal %}<li><i class="bi bi-search me-2"></i>{{ filters.input_principal }}</li>{% endif %}
                    {% if filters.input_busqueda %}<li><i class="bi bi-search me-2"></i>{{ filters.input_busqueda }}</li>{% endif %}
                    {% if filters.select_filters %}
                      <li><i class="bi bi-ui-radios me-2"></i>{{ filters.select_filters|join(', ') }}</li>
                    {% endif %}
                    {% if filters.select_seccion %}<li><i class="bi bi-layout-text-window me-2"></i>{{ filters.select_seccion }}</li>{% endif %}
                    {% if filters.select_campos %}<li><i class="bi bi-ui-checks me-2"></i>{{ filters.select_campos }}</li>{% endif %}
                  </ul>
                </div>
              {% endfor %}
            </div>
          </article>
        </div>
        {% endif %}

        {# Audit System Logic #}
        {% if module.developer_docs.audit_system_logic %}
        <div class="col-12">
          <article class="glass-panel p-4">
            <h3 class="h5 mb-3"><i class="bi bi-shield-check me-2 text-success"></i>Lógica de Auditoría</h3>
            <div class="row g-4">
              <div class="col-md-6">
                <p class="fw-semibold mb-2 small text-secondary">Entidades Evaluadas:</p>
                <ul class="list-group list-group-flush bg-transparent">
                  {% for key, eval in module.developer_docs.audit_system_logic.widgets_evaluated %}
                    <li class="list-group-item bg-transparent text-light border-secondary-subtle px-0 py-2 small">
                      <span class="text-info text-capitalize">{{ key|replace({'_': ' '}) }}:</span> <span class="text-secondary">{{ eval }}</span>
                    </li>
                  {% endfor %}
                </ul>
              </div>
              <div class="col-md-6">
                <div class="alert alert-success bg-success bg-opacity-10 border-success-subtle text-light small mb-0 h-100">
                  <i class="bi bi-check-circle-fill me-2 text-success"></i>
                  <strong>Estado de Éxito:</strong><br>
                  {{ module.developer_docs.audit_system_logic.success_state }}
                </div>
              </div>
            </div>
          </article>
        </div>
        {% endif %}

        {# Routing Reference #}
        {% if module.developer_docs.routing_reference %}
        <div class="col-12">
          <article class="glass-panel p-4">
            <div class="d-flex align-items-center gap-2 mb-1">
              <h3 class="h5 mb-0"><i class="bi bi-route me-2 text-danger"></i>Contrato de Enrutamiento Presupuestal</h3>
            </div>
            <p class="text-secondary small mb-3">
              Grupo de rutas con prefijo <code class="text-warning">/{{ module.developer_docs.routing_reference.prefix }}</code> y nombre base <code class="text-warning">{{ module.developer_docs.routing_reference.group_name }}</code>
            </p>
            <div class="table-responsive">
              <table class="table table-dark table-sm table-borderless align-middle mb-0" style="--bs-table-bg: transparent;">
                <thead class="border-bottom border-secondary-subtle">
                  <tr class="text-secondary small text-uppercase" style="letter-spacing:.04em">
                    <th class="ps-0" style="width:12%">Método</th>
                    <th style="width:38%">URI</th>
                    <th style="width:30%">Controlador @ Acción</th>
                    <th class="pe-0" style="width:20%">Nombre Alias</th>
                  </tr>
                </thead>
                <tbody>
                  {% for route in module.developer_docs.routing_reference.endpoints %}
                    <tr class="border-bottom border-dark-subtle small">
                      <td class="ps-0 py-2">
                        <span class="badge {% if route.method == 'GET' %}text-bg-success{% else %}text-bg-warning text-dark{% endif %} rounded-pill">{{ route.method }}</span>
                      </td>
                      <td class="py-2 font-monospace text-info">{{ route.uri }}</td>
                      <td class="text-secondary py-2 font-monospace">{{ route.action }}</td>
                      <td class="pe-0 py-2 text-warning font-monospace">{{ route.route_name }}</td>
                    </tr>
                  {% endfor %}
                </tbody>
              </table>
            </div>
          </article>
        </div>
        {% endif %}

        {# Environment Setup #}
        {% if module.developer_docs.environment_setup %}
        <div class="col-12">
          <article class="glass-panel p-4">
            <h3 class="h5 mb-3"><i class="bi bi-pc-display me-2 text-secondary"></i>Entorno de Desarrollo Local</h3>
            <div class="row g-4">
              <div class="col-md-5">
                <p class="fw-semibold mb-2 small text-secondary">Requisitos:</p>
                <div class="d-flex flex-wrap gap-2">
                  {% for req in module.developer_docs.environment_setup.requirements %}
                    <span class="badge bg-secondary bg-opacity-10 text-light border border-secondary-subtle">{{ req }}</span>
                  {% endfor %}
                </div>
              </div>
              <div class="col-md-7">
                <p class="fw-semibold mb-2 small text-secondary">Comandos Útiles:</p>
                <div class="d-flex flex-column gap-2">
                  {% for label, command in module.developer_docs.environment_setup.commands %}
                    <div class="d-flex justify-content-between align-items-center p-2 rounded bg-dark border border-secondary-subtle">
                      <span class="small text-secondary">{{ label }}</span>
                      <code class="text-info small">{{ command }}</code>
                    </div>
                  {% endfor %}
                </div>
              </div>
            </div>
          </article>
        </div>
        {% endif %}

      </div>
    </section>
  {% endif %}
  {# ── Módulos relacionados + Recursos ──────────────────────────────── #}
  <section class="row g-4" data-aos="fade-up" data-aos-delay="120">

    {% if module.related_modules %}
      <div class="col-lg-7">
        <article class="glass-panel p-4 p-lg-5 h-100">
          <h2 class="h5 mb-3">
            <i class="bi bi-diagram-2 me-2 text-info"></i>Módulos y servicios relacionados
          </h2>
          <div class="d-flex flex-column gap-3">
            {% for rel in module.related_modules %}
              <div class="workflow-step p-3">
                <div class="d-flex justify-content-between align-items-start gap-2 mb-1">
                  <p class="fw-semibold mb-0">{{ rel.label }}</p>
                  <a href="{{ rel.url ?? (homePath|trim('/') ~ '/' ~ rel.slug) }}"
                     class="btn btn-outline-secondary btn-sm rounded-pill px-2 py-0 flex-shrink-0">
                    Ver módulo <i class="bi bi-arrow-right-short"></i>
                  </a>
                </div>
                <p class="text-secondary mb-0">{{ rel.description }}</p>
              </div>
            {% endfor %}
          </div>
        </article>
      </div>
    {% endif %}

    {% if module.resources %}
      <div class="{{ module.related_modules ? 'col-lg-5' : 'col-12' }}">
        <article class="glass-panel p-4 p-lg-5">
          <h2 class="h5 mb-3">
            <i class="bi bi-link-45deg me-2 text-info"></i>Recursos
          </h2>
          <div class="d-flex flex-column gap-2">
            {% for item in module.resources %}
              <a href="{{ item.url }}" class="resource-link"
                 {% if item.url starts with 'http' %}target="_blank" rel="noopener noreferrer"{% endif %}>
                <i class="bi bi-box-arrow-up-right"></i> {{ item.label }}
              </a>
            {% endfor %}
          </div>
        </article>
      </div>
    {% endif %}
    </main>
  </div>
{% endblock %}
