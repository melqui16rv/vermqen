{% extends "layouts/base.twig" %}

{% block content %}
  <div class="modules-layout">
    {% include 'partials/sidebar.twig' %}
    <main class="modules-main">
      {# ── Back ────────────────────────────────────────────────────────── #}
      <a href="#" onclick="history.back(); return false;" class="btn btn-link text-secondary">
        Volver a la página anterior
      </a>

      {# ── Hero ────────────────────────────────────────────────────────── #}
  <section class="hero-card p-4 p-lg-5 mb-4" data-aos="fade-up" data-aos-duration="800">
    <div class="d-flex flex-wrap gap-2 mb-3">
      <span class="badge rounded-pill text-bg-dark border border-secondary-subtle">{{ module.tag }}</span>
      <span class="badge rounded-pill text-bg-primary-subtle text-primary-emphasis border border-primary-subtle">Manual</span>
    </div>
    <h1 class="display-6 fw-bold mb-3">{{ module.title }}</h1>
    <p class="lead text-secondary mb-0">{{ module.intro }}</p>
  </section>
  {# ── Glosario Interactivo (Nuevo) ────────────────────────────────── #}
  {% if module.glossary %}
    {% set glossaryTermMap = {} %}
    {% for glossaryItem in glossaryData %}
      {% set glossaryTermMap = glossaryTermMap|merge({ (glossaryItem.term|lower): glossaryItem.anchor }) %}
      {% if glossaryItem.aliases is defined and glossaryItem.aliases is iterable %}
        {% for alias in glossaryItem.aliases %}
          {% set glossaryTermMap = glossaryTermMap|merge({ (alias|lower): glossaryItem.anchor }) %}
        {% endfor %}
      {% endif %}
      {% if glossaryItem.sub_terms is defined and glossaryItem.sub_terms is iterable %}
        {% for subTerm in glossaryItem.sub_terms %}
          {% set glossaryTermMap = glossaryTermMap|merge({ (subTerm|lower): glossaryItem.anchor }) %}
        {% endfor %}
      {% endif %}
    {% endfor %}

    <section class="mb-4" data-aos="fade-in" data-aos-delay="50">
      <details class="glass-panel p-4">
        <summary class="h5 mb-0 d-flex align-items-center gap-2 cursor-pointer">
          <i class="bi bi-question-circle text-info"></i> {{ module.glossary.title }}
        </summary>
        <div class="mt-3 border-top pt-3">
          <div class="row g-3">
            {% for item in module.glossary.terms %}
              {% set lookupKey = item.term|lower %}
              {% set anchor = glossaryTermMap[lookupKey] ?? null %}
              <div class="col-md-6">
                <strong>
                  {% if anchor %}
                    <a href="{{ glossaryPath }}#glossary-{{ anchor }}" target="_blank" rel="noopener noreferrer" class="glossary-link-small">
                      {{ item.term }}
                    </a>
                  {% else %}
                    {{ item.term }}
                  {% endif %}
                  :
                </strong>
                <span class="text-secondary">{{ item.definition }}</span>
              </div>
            {% endfor %}
          </div>
          <div class="mt-3 p-3 bg-info bg-opacity-10 rounded">
            <small><strong>Relación:</strong> {{ module.glossary.relation }}</small>
          </div>
        </div>
      </details>
    </section>
  {% endif %} 

  {# ── Contribution (iframe legacy) ─────────────────────────────────── #}
  {% if module.contribution %}
    <section class="glass-panel p-4 p-lg-5 mb-4" data-aos="fade-up" data-aos-delay="80">
      <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-3">
        <div>
          <h2 class="h5 mb-1">{{ module.contribution.title }}</h2>
          <p class="text-secondary mb-0">{{ module.contribution.description }}</p>
        </div>
        <a class="btn btn-outline-info rounded-pill px-3 flex-shrink-0"
           href="{{ module.contribution.source }}" target="_blank" rel="noopener noreferrer">
          Abrir en pestaña nueva
        </a>
      </div>
      <iframe
        class="legacy-embed"
        src="{{ module.contribution.source }}"
        title="{{ module.contribution.title }}"
        loading="lazy"
        sandbox="allow-same-origin allow-scripts allow-popups allow-forms"
      ></iframe>
    </section>
  {% endif %}

  {# ── Pilares / conceptos clave ────────────────────────────────────── #}
  {% if module.pillars %}
    <section class="row g-3 g-lg-4 mb-4">
      {% for pillar in module.pillars %}
        <div class="col-md-4" data-aos="fade-up" data-aos-delay="{{ loop.index * 70 }}">
          <article class="module-card h-100 p-4">
            <div class="icon-pill mb-3"><i class="bi {{ pillar.icon }}"></i></div>
            <h2 class="h6">{{ pillar.title }}</h2>
            <p class="text-secondary mb-0">{{ pillar.text }}</p>
          </article>
        </div>
      {% endfor %}
    </section>
  {% endif %}
    {# ── Creación de Módulos desde Consola (CON IMÁGENES AL LADO) ────── #}
  {% if module.module_creation %}
    <section class="glass-panel p-4 p-lg-5 mt-4" data-aos="fade-up" data-aos-delay="85">
      <div class="d-flex align-items-center gap-2 mb-1">
        <div class="icon-pill"><i class="bi bi-terminal-dash"></i></div>
        <h2 class="h5 mb-0">{{ module.module_creation.title }}</h2>
      </div>
      <p class="text-secondary mb-4">{{ module.module_creation.description }}</p>

      <div class="d-flex flex-column gap-3">
        {% for step in module.module_creation.steps %}
          <div class="row g-3 align-items-start">
            <div class="col-lg-7">
              <div class="workflow-step p-3 p-lg-4 h-100">
                <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
                  <i class="bi {{ step.icon }} text-primary fs-5"></i>
                  <p class="fw-semibold mb-0">{{ step.label }}</p>
                  <code class="code-chip ms-auto text-warning">{{ step.path }}</code>
                </div>
                <p class="text-secondary mb-2 small">{{ step.description }}</p>
                {% if step.example %}
                  <pre class="mb-0 p-3 rounded-2 border border-secondary-subtle small"
                       style="background:rgba(0,0,0,.35);color:#e2e8f0;overflow-x:auto;white-space:pre;line-height:1.6"><code>{{ step.example }}</code></pre>
                {% endif %}
              </div>
            </div>
           {% if step.image %}
        <div class="col-lg-5">
        <img
    src="{{ step.image starts with '/' ? assetBase ~ step.image : step.image }}"
    alt="{{ step.label }}"
    class="img-fluid rounded-3 border border-secondary-subtle shadow-sm w-100"
    style="
        max-height:450px;
        object-fit:contain;
        background:rgba(255,255,255,.03);
        padding:10px;
    ">
        </div>
      {% endif %}
    </div>
        {% endfor %}
      </div>
    </section>
  {% endif %}


  {# ── Variables de entorno (.env) ─────────────────────────────────── #}
  {% if module.env_vars %}
    <section class="glass-panel p-4 p-lg-5 mb-4" data-aos="fade-up" data-aos-delay="100">
      <div class="d-flex align-items-center gap-2 mb-1">
        <div class="icon-pill"><i class="bi bi-file-earmark-code"></i></div>
        <h2 class="h5 mb-0">Configuración del archivo <code>.env</code></h2>
      </div>
      <p class="text-secondary mb-3">
        Variables de entorno requeridas antes de levantar el servidor. Copia
        <code>.env.example</code> como <code>.env</code> y completa los valores marcados como
        <span class="badge text-bg-danger rounded-pill ms-1">Requerido</span>.
      </p>
      <div class="table-responsive">
        <table class="table table-dark table-sm table-borderless align-middle mb-0" style="--bs-table-bg: transparent;">
          <thead class="border-bottom border-secondary-subtle">
            <tr class="text-secondary small text-uppercase" style="letter-spacing:.04em">
              <th class="ps-0" style="width:22%">Variable</th>
              <th style="width:22%">Valor de ejemplo</th>
              <th>Descripción</th>
              <th class="text-end pe-0" style="width:10%">Estado</th>
            </tr>
          </thead>
          <tbody>
            {% for env in module.env_vars %}
              <tr class="border-bottom border-dark-subtle">
                <td class="ps-0 py-2">
                  <code class="code-chip text-nowrap">{{ env.key }}</code>
                </td>
                <td class="py-2">
                  <span class="text-info font-monospace small">{{ env.value }}</span>
                </td>
                <td class="text-secondary py-2 small">{{ env.description }}</td>
                <td class="text-end pe-0 py-2">
                  {% if env.required %}
                    <span class="badge text-bg-danger rounded-pill">Requerido</span>
                  {% else %}
                    <span class="badge text-bg-secondary rounded-pill">Opcional</span>
                  {% endif %}
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </section>
  {% endif %}

  {# ── Flujo de pasos + Checklist + Recursos ────────────────────────── #}
  <section class="row g-4" data-aos="fade-up" data-aos-delay="120">

    {% if module.workflow %}
      <div class="col-lg-7">
        <article class="glass-panel p-4 p-lg-5 h-100">
          <h2 class="h5 mb-3"><i class="bi bi-list-ol me-2 text-primary"></i>Flujo paso a paso</h2>
          <div class="d-flex flex-column gap-3">
            {% for item in module.workflow %}
              <div class="workflow-step p-3">
                <code class="code-chip">{{ item.command }}</code>
                <p class="fw-semibold mb-1 mt-3">{{ item.step }}</p>
                <p class="text-secondary mb-0">{{ item.detail }}</p>
              </div>
            {% endfor %}
          </div>
        </article>
      </div>
    {% endif %}

    {# Solución del operador condicional usando sintaxis limpia de Twig #}
    <div class="{{ module.workflow is defined and module.workflow ? 'col-lg-5' : 'col-12' }}">

      {% if module.checklist %}
        <article class="glass-panel p-4 p-lg-5 mb-4">
          <h2 class="h5 mb-3"><i class="bi bi-check2-all me-2 text-success"></i>Checklist</h2>
          <ul class="list-unstyled d-flex flex-column gap-2 mb-0">
            {% for item in module.checklist %}
              <li class="d-flex gap-2">
                <i class="bi bi-check-circle-fill text-success flex-shrink-0 mt-1"></i>
                <span>{{ item }}</span>
              </li>
            {% endfor %}
          </ul>
        </article>
      {% endif %}

      {% if module.resources %}
        <article class="glass-panel p-4 p-lg-5">
          <h2 class="h5 mb-3"><i class="bi bi-link-45deg me-2 text-info"></i>Recursos</h2>
          <div class="d-flex flex-column gap-2">
            {% for item in module.resources %}
              <a href="{{ item.url }}" class="resource-link"
                 {% if item.url starts with 'http' %}target="_blank" rel="noopener noreferrer"{% endif %}>
                <i class="bi bi-box-arrow-up-right"></i> {{ item.label }}
              </a>
            {% endfor %}
          </div>
        </article>
      {% endif %}

    </div>
  </section>

  {# ── Guía: cómo agregar un módulo nuevo ───────────────────────────── #}
  {% if module.module_guide %}
    <section class="glass-panel p-4 p-lg-5 mt-4" data-aos="fade-up" data-aos-delay="80">
      <div class="d-flex align-items-center gap-2 mb-1">
        <div class="icon-pill"><i class="bi bi-boxes"></i></div>
        <h2 class="h5 mb-0">{{ module.module_guide.title }}</h2>
      </div>
      <p class="text-secondary mb-4">{{ module.module_guide.description }}</p>

      <div class="d-flex flex-column gap-3">
        {% for step in module.module_guide.steps %}
          <div class="workflow-step p-3 p-lg-4 {% if step.is_alert %}border border-warning border-2 bg-warning bg-opacity-10 shadow-lg{% endif %}" style="{% if step.is_alert %}transform: scale(1.02); z-index: 10;{% endif %}">
            {# Cabecera del paso #}
            <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
              <i class="bi {{ step.icon }} {% if step.is_alert %}text-warning{% else %}text-primary{% endif %} fs-5"></i>
              <p class="fw-semibold mb-0 {% if step.is_alert %}text-warning{% endif %}">{{ step.label }}</p>
              <code class="code-chip ms-auto {% if step.is_alert %}bg-warning text-dark{% else %}text-warning{% endif %}">{{ step.path }}</code>
            </div>
            {# Descripción #}
            <p class="text-secondary mb-2 small">{{ step.description }}</p>
            {# Ejemplo de código #}
            {% if step.example %}
              <pre class="mb-0 p-3 rounded-2 border border-secondary-subtle small"
                   style="background:rgba(0,0,0,.35);color:#e2e8f0;overflow-x:auto;white-space:pre;line-height:1.6"><code>{{ step.example }}</code></pre>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </section>
  {% endif %}

  {# ── Layout y Navegación del Módulo ───────────────────────────────── #}
  {% if module.layout_navigation %}
    <section class="glass-panel p-4 p-lg-5 mt-4" data-aos="fade-up" data-aos-delay="86">
      <div class="d-flex align-items-center gap-2 mb-1">
        <div class="icon-pill"><i class="bi bi-layout-sidebar"></i></div>
        <h2 class="h5 mb-0">{{ module.layout_navigation.title }}</h2>
      </div>
      <p class="text-secondary mb-4">{{ module.layout_navigation.description }}</p>

      <div class="d-flex flex-column gap-3">
        {% for step in module.layout_navigation.steps %}
          <div class="workflow-step p-3 p-lg-4 {% if step.is_alert %}border border-warning border-2 bg-warning bg-opacity-10 shadow-lg{% endif %}" style="{% if step.is_alert %}transform: scale(1.02); z-index: 10;{% endif %}">
            <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
              <i class="bi {{ step.icon }} {% if step.is_alert %}text-warning{% else %}text-primary{% endif %} fs-5"></i>
              <p class="fw-semibold mb-0 {% if step.is_alert %}text-warning{% endif %}">{{ step.label }}</p>
              {% if step.path %}
                <code class="code-chip ms-auto {% if step.is_alert %}bg-warning text-dark{% else %}text-warning{% endif %}">{{ step.path }}</code>
              {% endif %}
            </div>
            <p class="text-secondary mb-2 small">{{ step.description }}</p>
            {% if step.example %}
              <pre class="mb-0 p-3 rounded-2 border border-secondary-subtle small"
                   style="background:rgba(0,0,0,.35);color:#e2e8f0;overflow-x:auto;white-space:pre;line-height:1.6"><code>{{ step.example }}</code></pre>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </section>
  {% endif %}

  {# ── Implementación de Microservicios ─────────────────────────────── #}
  {% if module.microservice_guide %}
    <section class="glass-panel p-4 p-lg-5 mt-4" data-aos="fade-up" data-aos-delay="88">
      <div class="d-flex align-items-center gap-2 mb-1">
        <div class="icon-pill"><i class="bi bi-cpu"></i></div>
        <h2 class="h5 mb-0">{{ module.microservice_guide.title }}</h2>
      </div>
      <p class="text-secondary mb-4">{{ module.microservice_guide.description }}</p>

      <div class="d-flex flex-column gap-3">
        {% for step in module.microservice_guide.steps %}
          <div class="workflow-step p-3 p-lg-4 {% if step.is_alert %}border border-warning border-2 bg-warning bg-opacity-10 shadow-lg{% endif %}" style="{% if step.is_alert %}transform: scale(1.02); z-index: 10;{% endif %}">
            <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
              <i class="bi {{ step.icon }} {% if step.is_alert %}text-warning{% else %}text-primary{% endif %} fs-5"></i>
              <p class="fw-semibold mb-0 {% if step.is_alert %}text-warning{% endif %}">{{ step.label }}</p>
              {% if step.path %}
                <code class="code-chip ms-auto {% if step.is_alert %}bg-warning text-dark{% else %}text-warning{% endif %}">{{ step.path }}</code>
              {% endif %}
            </div>
            <p class="text-secondary mb-2 small">{{ step.description }}</p>
            {% if step.example %}
              <pre class="mb-0 p-3 rounded-2 border border-secondary-subtle small"
                   style="background:rgba(0,0,0,.35);color:#e2e8f0;overflow-x:auto;white-space:pre;line-height:1.6"><code>{{ step.example }}</code></pre>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </section>
  {% endif %}

  {# ── Configuración de Correos y Tinker ────────────────────────────── #}
  {% if module.email_setup %}
    <section class="glass-panel p-4 p-lg-5 mt-4" data-aos="fade-up" data-aos-delay="90">
      <div class="d-flex align-items-center gap-2 mb-1">
        <div class="icon-pill"><i class="bi bi-envelope-check"></i></div>
        <h2 class="h5 mb-0">{{ module.email_setup.title }}</h2>
      </div>
      <p class="text-secondary mb-4">{{ module.email_setup.description }}</p>

      <div class="d-flex flex-column gap-3">
        {% for step in module.email_setup.steps %}
          <div class="workflow-step p-3 p-lg-4">
            {# Cabecera del paso #}
            <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
              <i class="bi {{ step.icon }} text-primary fs-5"></i>
              <p class="fw-semibold mb-0">{{ step.label }}</p>
              <code class="code-chip ms-auto text-warning">{{ step.path }}</code>
            </div>
            {# Descripción #}
            <p class="text-secondary mb-2 small">{{ step.description|replace({ 'src="/assets/': 'src="'~assetBase~'/assets/', "src='/assets/": "src='"~assetBase~'/assets/' })|raw }}</p>
            {# Ejemplo de código #}
            {% if step.example %}
              <pre class="mb-0 p-3 rounded-2 border border-secondary-subtle small"
                   style="background:rgba(0,0,0,.35);color:#e2e8f0;overflow-x:auto;white-space:pre;line-height:1.6"><code>{{ step.example }}</code></pre>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </section>
  {% endif %}

  {# ── Compilación de Assets ────────────────────────────────────────── #}
  {% if module.assets_build %}
    <section class="glass-panel p-4 p-lg-5 mt-4" data-aos="fade-up" data-aos-delay="100">
      <div class="d-flex align-items-center gap-2 mb-1">
        <div class="icon-pill"><i class="bi bi-box-seam"></i></div>
        <h2 class="h5 mb-0">{{ module.assets_build.title }}</h2>
      </div>
      <p class="text-secondary mb-4">{{ module.assets_build.description }}</p>

      <div class="d-flex flex-column gap-3">
        {% for step in module.assets_build.steps %}
          <div class="workflow-step p-3 p-lg-4">
            <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
              <i class="bi {{ step.icon }} text-primary fs-5"></i>
              <p class="fw-semibold mb-0">{{ step.label }}</p>
              {% if step.path %}
                <code class="code-chip ms-auto text-warning">{{ step.path }}</code>
              {% endif %}
            </div>
            <p class="text-secondary mb-2 small">{{ step.description }}</p>
            {% if step.example %}
              <pre class="mb-0 p-3 rounded-2 border border-secondary-subtle small"
                   style="background:rgba(0,0,0,.35);color:#e2e8f0;overflow-x:auto;white-space:pre;line-height:1.6"><code>{{ step.example }}</code></pre>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </section>
  {% endif %}

  {# ── Gestión de Caché ─────────────────────────────────────────────── #}
  {% if module.cache_management %}
    <section class="glass-panel p-4 p-lg-5 mt-4" data-aos="fade-up" data-aos-delay="110">
      <div class="d-flex align-items-center gap-2 mb-1">
        <div class="icon-pill"><i class="bi bi-eraser-fill"></i></div>
        <h2 class="h5 mb-0">{{ module.cache_management.title }}</h2>
      </div>
      <p class="text-secondary mb-4">{{ module.cache_management.description }}</p>

      <div class="d-flex flex-column gap-3">
        {% for step in module.cache_management.steps %}
          <div class="workflow-step p-3 p-lg-4">
            <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
              <i class="bi {{ step.icon }} text-primary fs-5"></i>
              <p class="fw-semibold mb-0">{{ step.label }}</p>
              {% if step.path %}
                <code class="code-chip ms-auto text-warning">{{ step.path }}</code>
              {% endif %}
            </div>
            <p class="text-secondary mb-2 small">{{ step.description }}</p>
            {% if step.example %}
              <pre class="mb-0 p-3 rounded-2 border border-secondary-subtle small"
                   style="background:rgba(0,0,0,.35);color:#e2e8f0;overflow-x:auto;white-space:pre;line-height:1.6"><code>{{ step.example }}</code></pre>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </section>
  {% endif %}

  {# ── Comandos Peligrosos / Reset de BD ────────────────────────────── #}
  {% if module.refresh_command %}
    <section class="glass-panel p-4 p-lg-5 mt-4" data-aos="fade-up" data-aos-delay="110">
      <div class="d-flex align-items-center gap-2 mb-1">
        <div class="icon-pill"><i class="bi bi-database-exclamation text-danger"></i></div>
        <h2 class="h5 mb-0 text-danger">{{ module.refresh_command.title }}</h2>
      </div>
      <p class="text-secondary mb-4">{{ module.refresh_command.description|replace({ 'src="/assets/': 'src="'~assetBase~'/assets/', "src='/assets/": "src='"~assetBase~'/assets/' })|raw }}</p>

      {% if module.refresh_command.steps %}
        <div class="d-flex flex-column gap-3 mb-4">
          {% for step in module.refresh_command.steps %}
            <div class="workflow-step p-3 p-lg-4 border-danger-subtle">
              <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
                <i class="bi {{ step.icon }} text-danger fs-5"></i>
                <p class="fw-semibold mb-0">{{ step.label }}</p>
                {% if step.path %}
                  <code class="code-chip ms-auto text-warning">{{ step.path }}</code>
                {% endif %}
              </div>
              <p class="text-secondary mb-2 small">{{ step.description|raw }}</p>
              {% if step.example %}
                <pre class="mb-0 p-3 rounded-2 border border-secondary-subtle small"
                     style="background:rgba(0,0,0,.35);color:#e2e8f0;overflow-x:auto;white-space:pre;line-height:1.6"><code>{{ step.example }}</code></pre>
              {% endif %}
            </div>
          {% endfor %}
        </div>
      {% endif %}

      {% if module.refresh_command.workflow %}
        <h3 class="h6 mb-3 mt-4"><i class="bi bi-list-ol me-2 text-primary"></i>Resumen de ejecución</h3>
        <div class="d-flex flex-column gap-3">
          {% for item in module.refresh_command.workflow %}
            <div class="workflow-step p-3">
              <code class="code-chip">{{ item.command }}</code>
              <p class="fw-semibold mb-1 mt-3">{{ item.step }}</p>
              <p class="text-secondary mb-0">{{ item.detail }}</p>
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </section>
  {% endif %}
    </main>
  </div>

{% endblock %}