<!doctype html>
<html lang="es">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ pageTitle }} · APP CIDE</title>
    <meta name="description" content="Wiki colaborativa del proyecto APP-CIDE">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:wght@600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.4/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="https://unpkg.com/aos@2.3.4/dist/aos.css" rel="stylesheet">
    <link href="{{ assetBase }}/assets/css/app.css" rel="stylesheet">
</head>
<body class="wiki-body">
    <div class="page-loader" aria-hidden="true">
        <div class="loader-mark">
            <span class="loader-dot"></span>
            <span class="loader-text">APP-CIDE</span>
        </div>
    </div>
    <div class="bg-orb bg-orb-a"></div>
    <div class="bg-orb bg-orb-b"></div>
    <div class="bg-grid"></div>

    <div class="site-shell">
        <header class="site-header border-bottom border-dark-subtle" data-aos="fade-down" data-aos-duration="700">
            <nav class="navbar navbar-expand-lg navbar-dark py-3">
                <div class="container">
                    <a class="navbar-brand d-flex align-items-center gap-2" href="{{ navigation[0].path }}">
                        <i class="bi bi-brain brand-icon"></i>
                        <span class="brand-title">APP-CIDE</span>
                    </a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#wikiNav" aria-controls="wikiNav" aria-expanded="false" aria-label="Navegación">
                    </button>
                    <div class="navbar-actions ms-auto" id="wikiNav">
                        <ul class="navbar-nav ms-auto gap-lg-1 align-items-center">
                            <li class="nav-item">
                                <a class="nav-link rounded-pill px-3 {{ currentSlug is null ? 'active' : '' }}" href="{{ navigation[0].path }}">Inicio</a>
                            </li>
                            <li class="nav-item me-2">
                                <button type="button" class="btn btn-outline-light btn-sm theme-toggle" onclick="window.toggleTheme()" aria-label="Alternar modo claro/oscuro">
                                    <i class="bi bi-sun-fill theme-icon-light"></i>
                                    <i class="bi bi-moon-fill theme-icon-dark"></i>
                                </button>
                            </li>
                        </ul>
                    </div>
                </div>
            </nav>
        </header>
        <div class="content-wrapper">
            <main class="content-main">
                <div class="container py-4 py-lg-5" id="main-content">
                    {% block content %}{% endblock %}
                </div>
            </main>
        </div>

        {% if showFooter is not defined or showFooter %}
        <footer class="border-top border-dark-subtle py-4 mt-auto">
            <div class="container d-flex flex-column flex-md-row justify-content-between gap-2 text-secondary small">
                <span>APP-CIDE· Wiki colaborativa del proyecto</span>
                <span>Stack: Slim 4 · Twig · Bootstrap 5 · Alpine.js</span>
            </div>
        </footer>
        {% endif %}
    </div>

    {% if currentSlug != 'glosario' %}
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const glossaryPath = '{{ glossaryPath }}';
            const apiGlossary = '{{ assetBase }}/api/glosario';
            const glossaryMap = {};

            // Lazy-load glossary via API to avoid embedding large data on every page
            fetch(apiGlossary, { credentials: 'same-origin' }).then(resp => {
                if (!resp.ok) throw new Error('Glossary fetch failed');
                return resp.json();
            }).then(items => {
                if (!Array.isArray(items)) return;
                items.forEach(item => {
                    const anchor = String(item._id || '').trim();
                    if (!anchor) return;
                    const term = String(item.termino || '').trim().toLowerCase();
                    if (term) {
                        glossaryMap[term] = anchor;
                        const compact = term.replace(/\s+/g, '').replace(/[^a-z0-9]/gi, '');
                        if (compact && compact !== term) glossaryMap[compact] = anchor;
                    }
                    if (Array.isArray(item.aliases)) {
                        item.aliases.forEach(a => {
                            const aliasText = String(a || '').trim().toLowerCase();
                            if (!aliasText) return;
                            glossaryMap[aliasText] = anchor;
                            const compactA = aliasText.replace(/\s+/g, '').replace(/[^a-z0-9]/gi, '');
                            if (compactA && compactA !== aliasText) glossaryMap[compactA] = anchor;
                        });
                    }
                    if (item.sub_terms && typeof item.sub_terms === 'object') {
                        Object.keys(item.sub_terms).forEach(subTerm => {
                            const subText = String(subTerm || '').trim().toLowerCase();
                            if (!subText) return;
                            glossaryMap[subText] = anchor;
                            const compactS = subText.replace(/\s+/g, '').replace(/[^a-z0-9]/gi, '');
                            if (compactS && compactS !== subText) glossaryMap[compactS] = anchor;
                        });
                    }
                });

                const terms = Object.keys(glossaryMap).sort((a, b) => b.length - a.length);
                if (terms.length === 0) return;

                const content = document.getElementById('main-content');
                if (!content) return;

                const excluded = ['A', 'SCRIPT', 'STYLE', 'CODE', 'PRE', 'NAV', 'FOOTER', 'BUTTON', 'INPUT', 'TEXTAREA', 'SELECT', 'OPTION', 'H1', 'H2', 'H3'];
                const excludeSelectors = ['.module-card-title', '.category-name', '.sidebar-module-link', '.module-card', '.category-card', '.category-title'];
                const walker = document.createTreeWalker(content, NodeFilter.SHOW_TEXT, {
                    acceptNode: (node) => {
                        const parent = node.parentElement;
                        if (!parent) return NodeFilter.FILTER_REJECT;
                        if (excluded.includes(parent.tagName)) return NodeFilter.FILTER_REJECT;
                        for (const s of excludeSelectors) {
                            if (parent.closest && parent.closest(s)) return NodeFilter.FILTER_REJECT;
                        }
                        if (!node.nodeValue.trim()) return NodeFilter.FILTER_REJECT;
                        return NodeFilter.FILTER_ACCEPT;
                    }
                });

                const isWordChar = char => /[A-Za-z0-9_]/.test(char);
                const isUpper = char => /[A-ZÁÉÍÓÚÜÑ]/.test(char);
                const isLower = char => /[a-záéíóúüñ]/.test(char);

                const isValidTermBoundary = (text, start, length) => {
                    const before = start > 0 ? text[start - 1] : '';
                    const after = start + length < text.length ? text[start + length] : '';
                    const beforeWord = isWordChar(before);
                    const afterWord = isWordChar(after);

                    if (!beforeWord && !afterWord) return true;
                    if (!beforeWord && after && isUpper(after)) return true;
                    if (before && isLower(before) && after && isUpper(after)) return true;
                    if (before && isLower(before) && !afterWord && after === '') return true;
                    return false;
                };

                let node;
                while (node = walker.nextNode()) {
                    const originalText = node.nodeValue;
                    const lowerText = originalText.toLowerCase();
                    let cursor = 0;
                    let html = '';

                    while (cursor < originalText.length) {
                        let nextMatch = null;
                        let nextTerm = null;

                        for (const term of terms) {
                            const index = lowerText.indexOf(term, cursor);
                            if (index === -1) continue;
                            if (nextMatch === null || index < nextMatch || (index === nextMatch && term.length > nextTerm.length)) {
                                nextMatch = index;
                                nextTerm = term;
                            }
                        }

                        if (nextMatch === null) {
                            html += originalText.slice(cursor);
                            break;
                        }

                        if (nextMatch > cursor) {
                            html += originalText.slice(cursor, nextMatch);
                        }

                        const termStart = nextMatch;
                        const termLength = nextTerm.length;
                        const anchor = glossaryMap[nextTerm];

                        if (isValidTermBoundary(originalText, termStart, termLength)) {
                            const matchedText = originalText.slice(termStart, termStart + termLength);
                            html += `<a href="${glossaryPath}#glossary-${anchor}" class="glossary-link">${matchedText}</a>`;
                            cursor = termStart + termLength;
                        } else {
                            html += originalText[cursor];
                            cursor += 1;
                        }
                    }

                    if (html !== originalText) {
                        const span = document.createElement('span');
                        span.innerHTML = html;
                        node.parentNode.replaceChild(span, node);
                    }
                }
            }).catch(err => {
                // Fallback: if API fails, try using embedded glossaryData (if present)
                try {
                    const rawGloss = {{ glossaryData|json_encode|raw }};
                    const fallbackMap = {};
                    Object.values(rawGloss).forEach(item => {
                        const anchor = item.anchor;
                        if (!anchor) return;
                        const term = String(item.term || '').trim().toLowerCase();
                        if (term) {
                            fallbackMap[term] = anchor;
                            const compact = term.replace(/\s+/g, '').replace(/[^a-z0-9]/gi, '');
                            if (compact && compact !== term) fallbackMap[compact] = anchor;
                        }
                        if (Array.isArray(item.aliases)) {
                            item.aliases.forEach(alias => {
                                const aliasText = String(alias || '').trim().toLowerCase();
                                if (aliasText) {
                                    fallbackMap[aliasText] = anchor;
                                    const compactA = aliasText.replace(/\s+/g, '').replace(/[^a-z0-9]/gi, '');
                                    if (compactA && compactA !== aliasText) fallbackMap[compactA] = anchor;
                                }
                            });
                        }
                        if (item.sub_terms && typeof item.sub_terms === 'object') {
                            Object.keys(item.sub_terms).forEach(subTerm => {
                                const subText = String(subTerm || '').trim().toLowerCase();
                                if (subText) {
                                    fallbackMap[subText] = anchor;
                                    const compactS = subText.replace(/\s+/g, '').replace(/[^a-z0-9]/gi, '');
                                    if (compactS && compactS !== subText) fallbackMap[compactS] = anchor;
                                }
                            });
                        }
                    });

                    const terms = Object.keys(fallbackMap).sort((a, b) => b.length - a.length);
                    if (terms.length === 0) return;
                    const content = document.getElementById('main-content');
                    if (!content) return;
                    const excluded = ['A', 'SCRIPT', 'STYLE', 'CODE', 'PRE', 'NAV', 'FOOTER', 'BUTTON', 'INPUT', 'TEXTAREA', 'SELECT', 'OPTION', 'H1', 'H2', 'H3'];
                    const excludeSelectors = ['.module-card-title', '.category-name', '.sidebar-module-link', '.module-card', '.category-card', '.category-title'];
                    const walker = document.createTreeWalker(content, NodeFilter.SHOW_TEXT, {
                        acceptNode: (node) => {
                            const parent = node.parentElement;
                            if (!parent) return NodeFilter.FILTER_REJECT;
                            if (excluded.includes(parent.tagName)) return NodeFilter.FILTER_REJECT;
                            for (const s of excludeSelectors) {
                                if (parent.closest && parent.closest(s)) return NodeFilter.FILTER_REJECT;
                            }
                            if (!node.nodeValue.trim()) return NodeFilter.FILTER_REJECT;
                            return NodeFilter.FILTER_ACCEPT;
                        }
                    });

                    const isWordChar = char => /[A-Za-z0-9_]/.test(char);
                    const isUpper = char => /[A-ZÁÉÍÓÚÜÑ]/.test(char);
                    const isLower = char => /[a-záéíóúüñ]/.test(char);

                    const isValidTermBoundary = (text, start, length) => {
                        const before = start > 0 ? text[start - 1] : '';
                        const after = start + length < text.length ? text[start + length] : '';
                        const beforeWord = isWordChar(before);
                        const afterWord = isWordChar(after);

                        if (!beforeWord && !afterWord) return true;
                        if (!beforeWord && after && isUpper(after)) return true;
                        if (before && isLower(before) && after && isUpper(after)) return true;
                        if (before && isLower(before) && !afterWord && after === '') return true;
                        return false;
                    };

                    let node;
                    while (node = walker.nextNode()) {
                        const originalText = node.nodeValue;
                        const lowerText = originalText.toLowerCase();
                        let cursor = 0;
                        let html = '';

                        while (cursor < originalText.length) {
                            let nextMatch = null;
                            let nextTerm = null;

                            for (const term of terms) {
                                const index = lowerText.indexOf(term, cursor);
                                if (index === -1) continue;
                                if (nextMatch === null || index < nextMatch || (index === nextMatch && term.length > nextTerm.length)) {
                                    nextMatch = index;
                                    nextTerm = term;
                                }
                            }

                            if (nextMatch === null) {
                                html += originalText.slice(cursor);
                                break;
                            }

                            if (nextMatch > cursor) {
                                html += originalText.slice(cursor, nextMatch);
                            }

                            const termStart = nextMatch;
                            const termLength = nextTerm.length;
                            const anchor = fallbackMap[nextTerm];

                            if (isValidTermBoundary(originalText, termStart, termLength)) {
                                const matchedText = originalText.slice(termStart, termStart + termLength);
                                html += `<a href="${glossaryPath}#glossary-${anchor}" class="glossary-link">${matchedText}</a>`;
                                cursor = termStart + termLength;
                            } else {
                                html += originalText[cursor];
                                cursor += 1;
                            }
                        }

                        if (html !== originalText) {
                            const span = document.createElement('span');
                            span.innerHTML = html;
                            node.parentNode.replaceChild(span, node);
                        }
                    }
                } catch (e) {
                    console.warn('Autolink fallback failed', e);
                }
            });
                acceptNode: (node) => {
                    const parent = node.parentElement;
                    if (!parent) return NodeFilter.FILTER_REJECT;
                    if (excluded.includes(parent.tagName)) return NodeFilter.FILTER_REJECT;
                    for (const s of excludeSelectors) {
                        if (parent.closest && parent.closest(s)) return NodeFilter.FILTER_REJECT;
                    }
                    if (!node.nodeValue.trim()) return NodeFilter.FILTER_REJECT;
                    return NodeFilter.FILTER_ACCEPT;
                }
            });

            const isWordChar = char => /[A-Za-z0-9_]/.test(char);
            const isUpper = char => /[A-ZÁÉÍÓÚÜÑ]/.test(char);
            const isLower = char => /[a-záéíóúüñ]/.test(char);

            const isValidTermBoundary = (text, start, length) => {
                const before = start > 0 ? text[start - 1] : '';
                const after = start + length < text.length ? text[start + length] : '';
                const beforeWord = isWordChar(before);
                const afterWord = isWordChar(after);

                if (!beforeWord && !afterWord) return true;
                if (!beforeWord && after && isUpper(after)) return true;
                if (before && isLower(before) && after && isUpper(after)) return true;
                if (before && isLower(before) && !afterWord && after === '') return true;
                return false;
            };

            let node;
            while (node = walker.nextNode()) {
                const originalText = node.nodeValue;
                const lowerText = originalText.toLowerCase();
                let cursor = 0;
                let html = '';

                while (cursor < originalText.length) {
                    let nextMatch = null;
                    let nextTerm = null;

                    for (const term of terms) {
                        const index = lowerText.indexOf(term, cursor);
                        if (index === -1) continue;
                        if (nextMatch === null || index < nextMatch || (index === nextMatch && term.length > nextTerm.length)) {
                            nextMatch = index;
                            nextTerm = term;
                        }
                    }

                    if (nextMatch === null) {
                        html += originalText.slice(cursor);
                        break;
                    }

                    if (nextMatch > cursor) {
                        html += originalText.slice(cursor, nextMatch);
                    }

                    const termStart = nextMatch;
                    const termLength = nextTerm.length;
                    const anchor = glossaryMap[nextTerm];

                    if (isValidTermBoundary(originalText, termStart, termLength)) {
                        const matchedText = originalText.slice(termStart, termStart + termLength);
                        html += `<a href="${glossaryPath}#glossary-${anchor}" class="glossary-link">${matchedText}</a>`;
                        cursor = termStart + termLength;
                    } else {
                        html += originalText[cursor];
                        cursor += 1;
                    }
                }

                if (html !== originalText) {
                    const span = document.createElement('span');
                    span.innerHTML = html;
                    node.parentNode.replaceChild(span, node);
                }
            }
        });
    </script>
    {% endif %}

    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.4/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/aos@2.3.4/dist/aos.js"></script>
    <script src="{{ assetBase }}/assets/js/app.js"></script>
</body>
</html>