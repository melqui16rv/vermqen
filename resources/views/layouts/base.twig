<!doctype html>
<html lang="es">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ pageTitle }} · APP CIDE</title>
    <meta name="description" content="Wiki colaborativa del proyecto APP-CIDE">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:wght@600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.4/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="https://unpkg.com/aos@2.3.4/dist/aos.css" rel="stylesheet">
    <link href="{{ assetBase }}/assets/css/app.css" rel="stylesheet">
</head>
<body class="wiki-body">
    <div class="page-loader" aria-hidden="true">
        <div class="loader-mark">
            <span class="loader-dot"></span>
            <span class="loader-text">APP-CIDE</span>
        </div>
    </div>
    <div class="bg-orb bg-orb-a"></div>
    <div class="bg-orb bg-orb-b"></div>
    <div class="bg-grid"></div>

    <div class="site-shell">
        <header class="site-header border-bottom border-dark-subtle" data-aos="fade-down" data-aos-duration="700">
            <nav class="navbar navbar-expand-lg navbar-dark py-3">
                <div class="container">
                    <a class="navbar-brand d-flex align-items-center gap-2" href="{{ navigation[0].path }}">
                        <span class="brand-dot"></span>
                        <span class="brand-title">APP-CIDE</span>
                    </a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#wikiNav" aria-controls="wikiNav" aria-expanded="false" aria-label="Navegación">
                    </button>
                    <div class="navbar-actions ms-auto" id="wikiNav">
                        <ul class="navbar-nav ms-auto gap-lg-1 align-items-center">
                            <li class="nav-item">
                                <a class="nav-link rounded-pill px-3 {{ currentSlug is null ? 'active' : '' }}" href="{{ navigation[0].path }}">Inicio</a>
                            </li>
                            <li class="nav-item me-2">
                                <button type="button" class="btn btn-outline-light btn-sm theme-toggle" onclick="window.toggleTheme()" aria-label="Alternar modo claro/oscuro">
                                    <i class="bi bi-sun-fill theme-icon-light"></i>
                                    <i class="bi bi-moon-fill theme-icon-dark"></i>
                                </button>
                            </li>
                        </ul>
                    </div>
                </div>
            </nav>
        </header>
        <main class="content-main">
            <div class="container py-4 py-lg-5" id="main-content">
                {% block content %}{% endblock %}
            </div>
            
            <footer class="border-top border-dark-subtle py-4 mt-auto">
                <div class="container d-flex flex-column flex-md-row justify-content-between gap-2 text-secondary small">
                    <span>APP-CIDE· Wiki colaborativa del proyecto</span>
                    <span>Stack: Slim 4 · Twig · Bootstrap 5 · Alpine.js</span>
                </div>
            </footer>
        </main>

        <aside class="sidebar-right">
        </aside>
    </div>

    {% if currentSlug != 'glosario' %}
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const GLOSSARY_TERMS = ['crud', 'dashboard', 'devops']; // Actualiza esta lista según tu PHP
            const content = document.getElementById('main-content');
            
            const walker = document.createTreeWalker(content, NodeFilter.SHOW_TEXT, {
                acceptNode: (node) => {
                    const parent = node.parentElement.tagName;
                    const excluded = ['H1', 'H2', 'H3', 'H4', 'H5', 'H6', 'A', 'CODE', 'PRE', 'NAV', 'FOOTER', 'BUTTON', 'INPUT'];
                    return excluded.includes(parent) ? NodeFilter.FILTER_REJECT : NodeFilter.FILTER_ACCEPT;
                }
            });

            let node;
            while (node = walker.nextNode()) {
                let html = node.nodeValue;
                GLOSSARY_TERMS.forEach(term => {
                    const regex = new RegExp(`\\b(${term})\\b`, 'gi');
                    html = html.replace(regex, `<a href="/glosario#glossary-${term.toLowerCase()}" style="color: #8e44ad; text-decoration: underline dotted;">$1</a>`);
                });
                
                if (html !== node.nodeValue) {
                    const span = document.createElement('span');
                    span.innerHTML = html;
                    node.parentNode.replaceChild(span, node);
                }
            }
        });
    </script>
    {% endif %}

    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.4/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/aos@2.3.4/dist/aos.js"></script>
    <script src="{{ assetBase }}/assets/js/app.js"></script>
</body>
</html>